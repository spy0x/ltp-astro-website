---
import BaseLayout from "../../layouts/BaseLayout.astro";

export function getStaticPaths() {
  return [{ params: { lang: "en" } }, { params: { lang: "es" } }];
}

const { lang } = Astro.params;

if (lang !== "en" && lang !== "es") {
  return Astro.redirect("/en/");
}

const isEs = lang === "es";

const title = isEs ? "Los Tres Primos - Contacto" : "Los Tres Primos - Contact";
const description = isEs
  ? "Contáctanos en LTP Indie Game Development Studio."
  : "Contact us at LTP Indie Game Development Studio.";
---

<BaseLayout lang={lang} currentPage="contact" title={title} description={description}>
  <header class="container-fluid header__bar d-flex flex-column justify-content-center">
    <div class="d-flex justify-content-between align-items-center text-center">
      <i class="me-3 fa-solid fa-at fa-2x"></i>
      <h1 class="article__title m-0">{isEs ? "Contacto" : "Contact"}</h1>
      <i class="ms-3 fa-solid fa-at fa-2x"></i>
    </div>
  </header>

  <section class="container-fluid px-4 py-3">
    <article class="container-md article__container rounded-3 p-3">
      <div class="d-flex justify-content-center align-items-center">
        <img src="/img/Bed.png" alt="draw of us thinking game ideas" class="col-4 d-none d-md-block" />
        <div class="d-flex justify-content-center">
          <form action="https://formspree.io/f/xyknvjan" method="POST" id="formulario" class="d-flex flex-column" data-lang={lang}>
            <img data-aos="flip-right" data-aos-duration="500" data-aos-once="true" src="/img/Los3BIG.png" alt="us version pixelart" class="mx-auto d-block form__img" />
            <input type="text" name="_gotcha" class="d-none" tabindex="-1" autocomplete="off" />
            <input type="hidden" name="_form_started_at" id="form_started_at" value="" />
            <div class="d-flex flex-column mt-3">
              <label for="name">{isEs ? "Nombre" : "Name"}</label>
              <input class="form-control text-dark" type="text" placeholder={isEs ? "Tu nombre" : "Your name"} name="name" required />
            </div>
            <div class="d-flex flex-column mt-3">
              <label for="email">Email</label>
              <input class="form-control text-dark" type="email" placeholder="your@email.com" name="email" required />
            </div>
            <div class="d-flex flex-column mt-3">
              <label for="message">{isEs ? "Mensaje" : "Message"}</label>
              <textarea id="form__textArea" class="form-control text-dark" placeholder={isEs ? "Escribe tu mensaje aquí." : "Your message here."} name="message" required></textarea>
            </div>
            <div data-aos="zoom-in" data-aos-duration="500" data-aos-once="true">
              <button type="submit" form="formulario" value="Submit" class="btn form__button d-block mx-auto mt-3">{isEs ? "Enviar" : "Send"}</button>
            </div>
            <p id="form-feedback" class="text-center mt-3 mb-0 small" role="status" aria-live="polite"></p>
          </form>
        </div>
        <img src="/img/draw_our_faces.png" alt="draw of our faces" class="col-4 d-none d-md-block" />
      </div>
    </article>
  </section>
</BaseLayout>

<script>
  const formElement = document.getElementById("formulario");
  const feedback = document.getElementById("form-feedback");
  const submitButton = formElement?.querySelector('button[type="submit"]');
  const startedAtField = document.getElementById("form_started_at");

  if (
    formElement instanceof HTMLFormElement &&
    feedback instanceof HTMLElement &&
    submitButton instanceof HTMLButtonElement &&
    startedAtField instanceof HTMLInputElement
  ) {
    const form: HTMLFormElement = formElement;
    const feedbackEl: HTMLElement = feedback;
    const submitBtn: HTMLButtonElement = submitButton;
    const startedInput: HTMLInputElement = startedAtField;
    const startedAt = Date.now();
    startedInput.value = String(startedAt);

    const isSpanish = form.dataset.lang === "es";

    const messages = {
      sending: isSpanish ? "Enviando mensaje..." : "Sending message...",
      success: isSpanish ? "¡Mensaje enviado correctamente!" : "Message sent successfully!",
      error: isSpanish
        ? "No se pudo enviar el mensaje. Intenta nuevamente."
        : "Could not send the message. Please try again.",
      spam: isSpanish
        ? "Por favor espera unos segundos antes de enviar el formulario."
        : "Please wait a few seconds before submitting the form.",
    };

    form.addEventListener("submit", async (event) => {
      event.preventDefault();

      const elapsedMs = Date.now() - startedAt;
      if (elapsedMs < 3000) {
        feedbackEl.textContent = messages.spam;
        feedbackEl.className = "text-center mt-3 mb-0 small text-warning";
        return;
      }

      submitBtn.disabled = true;
      feedbackEl.textContent = messages.sending;
      feedbackEl.className = "text-center mt-3 mb-0 small text-light";

      try {
        const formData = new FormData(form);
        const response = await fetch(form.action, {
          method: "POST",
          body: formData,
          headers: {
            Accept: "application/json",
          },
        });

        if (!response.ok) {
          throw new Error("Submission failed");
        }

        form.reset();
        startedInput.value = String(Date.now());
        feedbackEl.textContent = messages.success;
        feedbackEl.className = "text-center mt-3 mb-0 small text-success";
      } catch {
        feedbackEl.textContent = messages.error;
        feedbackEl.className = "text-center mt-3 mb-0 small text-danger";
      } finally {
        submitBtn.disabled = false;
      }
    });
  }
</script>
